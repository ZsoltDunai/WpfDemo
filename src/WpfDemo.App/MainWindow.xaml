<Window x:Class="WpfDemo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        AutomationProperties.AutomationId="MainWindow"
        Title="Mini Shop Admin"
        Height="420"
        Width="520"
        MinHeight="380"
        MinWidth="460"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Mini Shop Admin"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="1"
                   Text="Manage products, settings, and customer greetings."
                   Foreground="#4B5563"
                   Margin="0,0,0,16" />

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Admin name" Margin="0,0,0,4" />
            <TextBox x:Name="NameTextBox"
                     AutomationProperties.AutomationId="NameTextBox"
                     AutomationProperties.Name="Admin name"
                     Height="32"
                     Padding="8,4" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <Button x:Name="GreetButton"
                    AutomationProperties.AutomationId="GreetButton"
                    AutomationProperties.Name="Say Hello"
                    Content="Say Hello"
                    Height="36"
                    Width="110"
                    Margin="0,0,8,0"
                    Click="GreetButton_Click" />
            <Button AutomationProperties.AutomationId="OpenCatalogButton"
                    AutomationProperties.Name="Open Catalog"
                    Content="Catalog"
                    Height="36"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="OpenCatalogButton_Click" />
            <Button AutomationProperties.AutomationId="OpenSettingsButton"
                    AutomationProperties.Name="Open Settings"
                    Content="Settings"
                    Height="36"
                    Width="100"
                    Margin="0,0,8,0"
                    Click="OpenSettingsButton_Click" />
            <Button AutomationProperties.AutomationId="OpenAboutButton"
                    AutomationProperties.Name="Open About"
                    Content="About"
                    Height="36"
                    Width="90"
                    Click="OpenAboutButton_Click" />
        </StackPanel>

        <TextBox Grid.Row="4"
                 x:Name="ProductSummaryTextBox"
                 AutomationProperties.AutomationId="ProductSummaryTextBox"
                 Margin="0,0,0,12"
                 IsReadOnly="True"
                 BorderThickness="0"
                 Background="#EEF2FF"
                 Padding="12,8"
                 Text="Products in catalog: 2" />

        <Border Grid.Row="5"
                Padding="12"
                Background="#F3F4F6"
                CornerRadius="6">
            <TextBox x:Name="GreetingTextBox"
                     AutomationProperties.AutomationId="GreetingTextBox"
                     Text="Enter a name and click Say Hello."
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     TextWrapping="Wrap"
                     VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
