<Window x:Class="WpfDemo.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        AutomationProperties.AutomationId="AboutWindow"
        Title="About"
        Height="220"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="About Mini Shop Admin"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <TextBox Grid.Row="1"
                 x:Name="AboutTextBox"
                 AutomationProperties.AutomationId="AboutTextBox"
                 Text="Mini Shop Admin demo&#x0a;Version 1.0.0&#x0a;Built for end-to-end UI testing."
                 IsReadOnly="True"
                 BorderThickness="0"
                 Background="Transparent"
                 TextWrapping="Wrap"
                 VerticalAlignment="Top" />

        <Button Grid.Row="2"
                AutomationProperties.AutomationId="CloseAboutButton"
                AutomationProperties.Name="Close"
                Content="Close"
                Width="90"
                Height="32"
                HorizontalAlignment="Right"
                Click="CloseButton_Click" />
    </Grid>
</Window>
